{
  "_meta": {
    "note": "Curated, precision-first client-side secret ruleset. Targets ONLY material that must never appear in a browser bundle. `allow` patterns are matched FIRST and hard-drop known-public tokens (Firebase/Maps/Stripe-publishable/Sentry/reCAPTCHA/GA/Algolia-search) before any rule fires. Generic high-entropy matching is deliberately excluded in v1 (the false-positive firehose). Each rule: `patterns` (regex, one capture group = the secret; matched case-insensitively unless the pattern is case-specific), `severity`, `title`.",
    "reference": "shapes adapted from gitleaks / trufflehog / GitHub secret-scanning public patterns"
  },
  "allow": [
    "AIza[0-9A-Za-z_\\-]{35}",
    "\\bpk_live_[0-9A-Za-z]{10,}",
    "\\bpk_test_[0-9A-Za-z]{10,}",
    "\\brk_live_[0-9A-Za-z]{10,}",
    "https?://[0-9a-f]+@o[0-9]+\\.ingest\\.sentry\\.io/[0-9]+",
    "\\b6L[0-9A-Za-z_\\-]{38}\\b",
    "\\bUA-[0-9]{4,10}-[0-9]{1,4}\\b",
    "\\bG-[A-Z0-9]{8,12}\\b",
    "\\bGTM-[A-Z0-9]{5,8}\\b",
    "[a-z0-9]{32}-dsn\\.algolia\\.net"
  ],
  "rules": [
    {
      "id": "private-key",
      "title": "Private key material exposed in JS",
      "severity": "critical",
      "mask": false,
      "patterns": [
        "(-----BEGIN (?:RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY-----)"
      ]
    },
    {
      "id": "aws-secret-key",
      "title": "AWS secret access key exposed in JS",
      "severity": "critical",
      "patterns": [
        "(?i)aws(?:.{0,20})?(?:secret|private)(?:.{0,20})?['\"]([A-Za-z0-9/+=]{40})['\"]"
      ]
    },
    {
      "id": "aws-access-key-id",
      "title": "AWS access key ID exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b((?:AKIA|ASIA|AGPA|AIDA|AROA|ANPA|ANVA)[A-Z0-9]{16})\\b"
      ]
    },
    {
      "id": "gcp-service-account",
      "title": "GCP service-account private key exposed in JS",
      "severity": "critical",
      "mask": false,
      "patterns": [
        "(\"type\"\\s*:\\s*\"service_account\")",
        "(\"private_key_id\"\\s*:\\s*\"[0-9a-f]{40}\")"
      ]
    },
    {
      "id": "db-connection-string",
      "title": "Database connection string with embedded password exposed in JS",
      "severity": "critical",
      "patterns": [
        "((?:postgres|postgresql|mysql|mongodb(?:\\+srv)?|redis|amqp)://[^:@/\\s\"']+:[^@/\\s\"']+@[^\\s\"']+)"
      ]
    },
    {
      "id": "stripe-secret-key",
      "title": "Stripe secret key exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(sk_live_[0-9A-Za-z]{20,})\\b",
        "\\b(rk_live_[0-9A-Za-z]{20,})\\b"
      ]
    },
    {
      "id": "github-token",
      "title": "GitHub token exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b((?:ghp|gho|ghu|ghs|ghr)_[0-9A-Za-z]{36,})\\b",
        "\\b(github_pat_[0-9A-Za-z_]{60,})\\b"
      ]
    },
    {
      "id": "slack-token",
      "title": "Slack token exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(xox[baprs]-[0-9A-Za-z-]{10,})\\b",
        "(https://hooks\\.slack\\.com/services/T[0-9A-Za-z_]+/B[0-9A-Za-z_]+/[0-9A-Za-z]+)"
      ]
    },
    {
      "id": "google-oauth-secret",
      "title": "Google OAuth client secret exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(GOCSPX-[0-9A-Za-z_\\-]{20,})\\b"
      ]
    },
    {
      "id": "twilio-key",
      "title": "Twilio API key exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(SK[0-9a-fA-F]{32})\\b"
      ]
    },
    {
      "id": "sendgrid-key",
      "title": "SendGrid API key exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(SG\\.[0-9A-Za-z_\\-]{22}\\.[0-9A-Za-z_\\-]{43})\\b"
      ]
    },
    {
      "id": "npm-token",
      "title": "npm access token exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(npm_[0-9A-Za-z]{36})\\b"
      ]
    },
    {
      "id": "openai-key",
      "title": "OpenAI API key exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(sk-(?:proj-)?[0-9A-Za-z_\\-]{40,})\\b"
      ]
    },
    {
      "id": "mailgun-key",
      "title": "Mailgun API key exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(key-[0-9a-f]{32})\\b"
      ]
    },
    {
      "id": "square-token",
      "title": "Square access token exposed in JS",
      "severity": "high",
      "patterns": [
        "\\b(sq0atp-[0-9A-Za-z_\\-]{22})\\b",
        "\\b(sq0csp-[0-9A-Za-z_\\-]{43})\\b"
      ]
    },
    {
      "id": "basic-auth-url",
      "title": "Credentials embedded in a URL exposed in JS",
      "severity": "medium",
      "patterns": [
        "(https?://[^:@/\\s\"']+:[^@/\\s\"']{3,}@[^\\s\"']+)"
      ]
    }
  ]
}
