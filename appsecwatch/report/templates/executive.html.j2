{% extends "_base.html.j2" %}
{% block title %}<title>Executive Summary — {{ executive.org_name }}</title>{% endblock %}
{% block extra_styles %}
  .exec-letterhead { display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
  .exec-letterhead img.logo { max-height:40px; max-width:160px; }
  .exec-letterhead .lh-org { font-size:20px; font-weight:600; letter-spacing:.2px; }
  .exec-letterhead .lh-sub { color:var(--muted); font-size:12px; margin-top:2px; }
  .classification { display:inline-block; padding:3px 10px; border-radius:6px; font-size:11px;
    font-weight:600; text-transform:uppercase; letter-spacing:.6px;
    color:var(--high); background:rgba(255,138,61,.12); border:1px solid rgba(255,138,61,.35); }
  .posture { display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; margin:6px 0 2px; }
  .posture .rating { font-size:30px; font-weight:700; letter-spacing:.5px; }
  .posture .rating.r-CRITICAL { color:var(--crit); }
  .posture .rating.r-HIGH { color:var(--high); }
  .posture .rating.r-MODERATE { color:var(--med); }
  .posture .rating.r-LOW { color:var(--pass); }
  .posture .volume { color:var(--muted); font-size:13px; }
  .narrative { margin:10px 0 4px; max-width:80ch; }
  .counts { display:flex; gap:8px; flex-wrap:wrap; margin:6px 0; }
  .risk { padding:12px 0; border-bottom:1px solid var(--border); }
  .risk:last-child { border-bottom:none; }
  .risk .rk-head { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .risk .rk-title { font-weight:600; }
  .risk .rk-hosts { color:var(--muted); font-size:12px; }
  .risk .rk-why { color:var(--text); margin-top:4px; max-width:80ch; }
  ul.recos { margin:6px 0 0; padding-left:20px; }
  ul.recos li { margin:4px 0; }
  .exec-foot { color:var(--muted); font-size:12px; margin-top:10px; }
  .more-note { color:var(--muted); font-size:12px; font-style:italic; margin-top:8px; }
  .exec-charts { display:grid; grid-template-columns: auto 1fr; gap:20px; align-items:center; margin-top:14px; }
  .exec-charts .chart-block { min-width:0; }
  .exec-charts .chart-label { color:var(--muted); font-size:11px; text-transform:uppercase; letter-spacing:.4px; margin-bottom:4px; }
  @media print { @page { margin:14mm; } section { break-inside: avoid; } }
  @media (max-width:640px) { .exec-charts { grid-template-columns: 1fr; } }
{% endblock %}
{% block header_title %}
  <div class="exec-letterhead">
    {% if executive.logo_data_uri %}<img class="logo" src="{{ executive.logo_data_uri }}" alt="logo">{% endif %}
    <div>
      <div class="lh-org">{{ executive.org_name }}</div>
      <div class="lh-sub">{{ executive.strings.subtitle }}</div>
    </div>
  </div>
{% endblock %}
{% block header_actions %}
  {% if executive.classification %}<span class="classification">{{ executive.classification }}</span>{% endif %}
{% endblock %}
{% block content %}
<main>

  {% if executive.degraded.flag %}
  <div class="degraded-banner">
    <strong>⚠ Scan degraded — this rating is not reliable.</strong>
    {{ executive.degraded.reason }}. The posture below reflects almost no audited
    surface; re-run before drawing conclusions.
  </div>
  {% endif %}

  <section id="exec-overview">
    <div class="head"><h2>{{ executive.strings.risk_posture }}</h2></div>
    <div class="body">
      <div class="lh-sub" style="margin-bottom:8px;">
        {% if executive.scope %}{{ executive.strings.scope }}: <strong>{{ executive.scope }}</strong> · {% endif %}{{ executive.date }}
      </div>
      <div class="posture">
        <span class="rating r-{{ executive.rating }}">{{ executive.rating_label }}</span>
        <span class="volume">{{ executive.volume_note }}</span>
      </div>
      <p class="narrative">{{ executive.narrative }}</p>

      <div class="exec-charts">
        <div class="chart-block">
          <div class="chart-label">{{ executive.strings.findings_by_severity }}</div>
          {{ executive.charts.donut | safe }}
        </div>
        <div class="chart-block">
          {% if executive.has_history %}
          <div class="chart-label">{{ executive.strings.risk_trend }}</div>
          {{ executive.charts.trend | safe }}
          {% endif %}
          {% if executive.diff %}
          <div class="chart-label" style="margin-top:10px;">{{ executive.strings.since_last_scan }}</div>
          {{ executive.charts.delta | safe }}
          {% endif %}
        </div>
      </div>

      <div class="counts">
        {% for sev in ["critical","high","medium","low","info"] %}
          <span class="{{ sev | sev_class }}">{{ sev }}: {{ executive.counts[sev] }}</span>
        {% endfor %}
      </div>

      <div class="grid" style="margin-top:12px;">
        <div class="stat"><div class="k">{{ executive.strings.live_web_servers }}</div><div class="v">{{ executive.scale.live_servers }}</div>
          <div class="sub">{{ executive.strings.responded_http }}</div></div>
        <div class="stat"><div class="k">{{ executive.strings.live_assets }}</div><div class="v">{{ executive.scale.live }}</div>
          <div class="sub">{{ executive.strings.resolved_dns }}</div></div>
        <div class="stat"><div class="k">{{ executive.strings.dead_dangling }}</div><div class="v">{{ executive.scale.dead }}</div>
          <div class="sub">{{ executive.strings.takeover_watch }}</div></div>
      </div>

      {% if executive.coverage_strip %}
      <div class="cov-strip" style="margin-top:14px;">
        <span class="cov-label">{{ executive.strings.assessed }}</span>
        {% for c in executive.coverage_strip %}
          {% set cls = 'partial' if (c.ran and c.partial) else ('ran' if c.ran else 'skipped') %}
          {% set sym = '~' if (c.ran and c.partial) else ('✓' if c.ran else '✗') %}
          <span class="cov-chip {{ cls }}">{{ c.token }} {{ sym }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </section>

  <section id="exec-risks">
    <div class="head"><h2>{{ executive.strings.top_risks }}</h2></div>
    <div class="body">
      {% if executive.risks %}
      {% for r in executive.risks %}
        <div class="risk">
          <div class="rk-head">
            <span class="{{ r.severity | sev_class }}">{{ r.severity }}</span>
            <span class="rk-title">{{ r.title }}</span>
            <span class="rk-hosts">· {{ r.host_count }} {{ executive.strings.host if r.host_count == 1 else executive.strings.hosts }}</span>
          </div>
          <div class="rk-why">{{ r.why }}</div>
        </div>
      {% endfor %}
      <div class="more-note">{{ executive.strings.full_findings_note }}</div>
      {% else %}
      <div class="empty">{{ executive.strings.clean_assessment }}</div>
      {% endif %}
    </div>
  </section>

  {% if executive.recommendations %}
  <section id="exec-recos">
    <div class="head"><h2>{{ executive.strings.recommended_next_steps }}</h2></div>
    <div class="body">
      <ul class="recos">
        {% for rec in executive.recommendations %}<li>{{ rec }}</li>{% endfor %}
      </ul>
    </div>
  </section>
  {% endif %}

  <div class="exec-foot">
    {% if not executive.ai_used %}{{ executive.strings.ai_not_run }} {% endif %}
    Generated by AppSecWatch{% if run.appsecwatch_version %} v{{ run.appsecwatch_version }}{% endif %} · point-in-time external assessment.
  </div>

</main>
{% endblock %}
{% block footer %}{{ executive.org_name }} · {{ executive.classification }} · executive summary{% endblock %}
